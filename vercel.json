{
  "version": 2,
  "_version_comment": "Vercel platform version",

  "name": "vercel-xhttp-relay",
  "_name_comment": "Project identifier",

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index",
      "_comment": "Catch all routes and forward to API handler"
    }
  ],

  "trailingSlash": false,
  "_trailingSlash_comment": "Disable automatic trailing slash behavior"
}
